generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique
  email      String   @unique
  name       String?
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sprints      Sprint[]
  devProfiles  DevProfile[]

  @@map("users")
}

enum DevRole {
  frontend
  backend
}

enum DevSeniority {
  junior
  senior
}

model DevProfile {
  id          String       @id @default(uuid())
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  name        String
  role        DevRole
  seniority   DevSeniority
  accessToken String       @unique
  isActive    Boolean      @default(true)
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  taskAssignments     TaskAssignee[]
  createdCommitments  DailyCommitment[] @relation("DailyCommitmentCreatedBy")
  checkIns            TaskCheckIn[]
  retros              TaskRetro[]
  silentFlags         TaskSilentFlag[]

  @@index([ownerId, isActive, createdAt])
  @@index([accessToken])
  @@map("dev_profiles")
}

model Sprint {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]

  @@index([ownerId, startDate])
  @@map("sprints")
}

model Task {
  id             String     @id @default(uuid())
  sprintId       String
  sprint         Sprint     @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  rationale      String?
  position       Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assignees      TaskAssignee[]
  commitments    DailyCommitment[]
  checkIns       TaskCheckIn[]
  retros         TaskRetro[]
  silentFlags    TaskSilentFlag[]

  @@index([sprintId, position, createdAt])
  @@map("tasks")
}

model TaskAssignee {
  taskId       String
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  devProfileId String
  devProfile   DevProfile @relation(fields: [devProfileId], references: [id], onDelete: Restrict)
  createdAt    DateTime   @default(now())

  @@id([taskId, devProfileId])
  @@index([devProfileId])
  @@map("task_assignees")
}

enum CheckInStatus {
  OnTrack
  Blocked
  TaskChanged
}

enum RetroOutcome {
  Done
  InProgress
  NotStarted
}

model DailyCommitment {
  taskId      String
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sprintDay   DateTime   @db.Date
  createdById String
  createdBy   DevProfile @relation("DailyCommitmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime   @default(now())

  @@id([taskId, sprintDay])
  @@index([sprintDay])
  @@index([createdById])
  @@map("daily_commitments")
}

model TaskCheckIn {
  taskId       String
  task         Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  devProfileId String
  devProfile   DevProfile    @relation(fields: [devProfileId], references: [id], onDelete: Restrict)
  sprintDay    DateTime      @db.Date
  status       CheckInStatus
  note         String?
  submittedAt  DateTime      @default(now())

  @@id([taskId, devProfileId, sprintDay])
  @@index([devProfileId, sprintDay])
  @@map("task_check_ins")
}

model TaskRetro {
  taskId       String
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  devProfileId String
  devProfile   DevProfile   @relation(fields: [devProfileId], references: [id], onDelete: Restrict)
  sprintDay    DateTime     @db.Date
  outcome      RetroOutcome
  submittedAt  DateTime     @default(now())

  @@id([taskId, devProfileId, sprintDay])
  @@index([devProfileId, sprintDay])
  @@map("task_retros")
}

model TaskSilentFlag {
  taskId       String
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  devProfileId String
  devProfile   DevProfile @relation(fields: [devProfileId], references: [id], onDelete: Restrict)
  sprintDay    DateTime   @db.Date
  flaggedAt    DateTime   @default(now())

  @@id([taskId, devProfileId, sprintDay])
  @@index([devProfileId, sprintDay])
  @@map("task_silent_flags")
}
